# ── Required ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/vallartapulse

# ── Server (optional — defaults shown) ──────────────────────────────────────
PORT=3001
BASE_PATH=/

# ── Frontend API override (optional) ────────────────────────────────────────
# Set only when the API runs on a different origin from the frontend.
# VITE_API_BASE_URL=https://api.vallartapulse.com

# ── Contact form (optional) ──────────────────────────────────────────────────
CONTACT_FROM_EMAIL=you@gmail.com
CONTACT_TO_EMAIL=you@gmail.com
CONTACT_FROM_PASSWORD=your-gmail-app-password
