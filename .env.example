# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string used by the API server and DB package.
DATABASE_URL=postgresql://user:password@localhost:5432/vallartapulse

# ── API server ────────────────────────────────────────────────────────────────
# Port the Express API server listens on.
PORT=8080

# Comma-separated allowlist of origins permitted to call the API.
# Leave unset for local development (any origin allowed, mirrors prior default).
# Production example:
# CORS_ORIGINS=https://www.vallartapulse.com,https://vallartapulse.com,https://vallartapulse.vercel.app
# CORS_ORIGINS=

# ── Frontend (pv-datastore / Vite) ────────────────────────────────────────────
# Port the Vite dev server listens on. Defaults to 5173 if unset.
# PORT=5173

# URL prefix under which the frontend is served.  Set to "/" for root-mounted
# deployments; set to "/pv-datastore" for sub-path deployments. Defaults to "/".
BASE_PATH=/

# Absolute base URL of the API server, used at BUILD TIME by the Vite frontend.
# Leave unset for local development and same-origin deployments — relative
# "/api/..." requests will hit whichever origin served the page.
# Set this when the API runs on a separate origin (e.g. Vercel + Railway):
# VITE_API_URL=https://api.vallartapulse.com

# ── Email (contact form) ─────────────────────────────────────────────────────
# Gmail app password used by the contact-form route to send emails via nodemailer.
# Generate an app password at https://myaccount.google.com/apppasswords
GMAIL_CONTACT_FORM_PASSWORD=your-gmail-app-password

# ── Affiliate / data integrations ────────────────────────────────────────────
# Awin affiliate network API token (used by the data-source sync scheduler).
AWIN_API_TOKEN=your-awin-api-token
