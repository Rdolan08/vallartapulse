modules = ["nodejs-22"]

  [[artifacts]]
  id = "artifacts/api-server"

  [[artifacts]]
  id = "artifacts/mockup-sandbox"

  [deployment]
  deploymentTarget = "autoscale"
  build = ["sh", "-c", "pnpm install --frozen-lockfile && pnpm build"]
  run = ["sh", "-c", "pnpm start"]

  [workflows]
  runButton = "Project"

  [agent]
  stack = "PNPM_WORKSPACE"
expertMode = true
  integrations = ["github:1.0.0"]

  [postMerge]
  path = "scripts/post-merge.sh"
  timeoutMs = 20000
  